# OpenAI-compatible chat completions configuration.
# When AI_API_KEY is omitted, API routes fall back to mock responses.
AI_API_KEY=

# Base URL for the provider. The backend appends /v1/chat/completions.
AI_API_BASE_URL=https://api.openai.com

# Model name passed to the chat completions endpoint.
AI_MODEL=gpt-4o-mini
